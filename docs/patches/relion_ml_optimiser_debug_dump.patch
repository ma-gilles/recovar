+// ---- Env-gated operand dump infrastructure (zero cost when RELION_DUMP_DIR is unset) ----
+static bool __relion_dump_enabled = false;
+static std::string __relion_dump_dir = "";
+static long __relion_dump_target_sorted = -1;  // sorted particle index to dump
+static long __relion_dump_target_part_id = -1; // original part_id to dump
+static long __relion_dump_target_stack_index = -1; // stack index from rlnImageName to dump
+static bool __relion_dump_init_done = false;
+
+static void __relion_dump_init() {
+    if (__relion_dump_init_done) return;
+    __relion_dump_init_done = true;
+    const char* env = getenv("RELION_DUMP_DIR");
+    if (env && strlen(env) > 0) {
+        __relion_dump_enabled = true;
+        __relion_dump_dir = std::string(env);
+        const char* target = getenv("RELION_DUMP_PART");
+        const char* target_part_id = getenv("RELION_DUMP_PART_ID");
+        const char* target_stack_index = getenv("RELION_DUMP_STACK_INDEX");
+        __relion_dump_target_sorted = target ? atol(target) : 0;
+        __relion_dump_target_part_id = target_part_id ? atol(target_part_id) : -1;
+        __relion_dump_target_stack_index = target_stack_index ? atol(target_stack_index) : -1;
+        std::cerr << "[DUMP] enabled: dir=" << __relion_dump_dir
+                  << " target_sorted_part=" << __relion_dump_target_sorted
+                  << " target_part_id=" << __relion_dump_target_part_id
+                  << " target_stack_index=" << __relion_dump_target_stack_index << std::endl;
+    }
+}
+
+static bool __relion_dump_matches_particle(const Experiment& mydata, long int part_id)
+{
+    __relion_dump_init();
+    if (!__relion_dump_enabled)
+        return false;
+    if (__relion_dump_target_stack_index >= 0)
+    {
+        FileName fn_img = mydata.particles[part_id].name;
+        FileName fn_stack;
+        long int imgno = -1;
+        fn_img.decompose(imgno, fn_stack);
+        if (imgno == __relion_dump_target_stack_index)
+            return true;
+    }
+    if (__relion_dump_target_part_id >= 0 && part_id == __relion_dump_target_part_id)
+        return true;
+    return __relion_dump_target_part_id < 0 && part_id == mydata.sorted_idx[__relion_dump_target_sorted];
+}
+
+// Write a MultidimArray<RFLOAT> as raw binary: [ydim:i32][xdim:i32][data:RFLOAT*ydim*xdim]
+static void __relion_dump_real(const std::string& name, const MultidimArray<RFLOAT>& arr) {
+    if (!__relion_dump_enabled) return;
+    std::string path = __relion_dump_dir + "/" + name + ".bin";
+    std::ofstream f(path, std::ios::binary);
+    int32_t ydim = YSIZE(arr), xdim = XSIZE(arr);
+    f.write(reinterpret_cast<const char*>(&ydim), sizeof(int32_t));
+    f.write(reinterpret_cast<const char*>(&xdim), sizeof(int32_t));
+    f.write(reinterpret_cast<const char*>(arr.data), (long)ydim * xdim * sizeof(RFLOAT));
+    f.close();
+    std::cerr << "[DUMP] " << name << " shape=(" << ydim << "," << xdim << ")" << std::endl;
+}
+
+// Write a MultidimArray<Complex> as raw binary: [ydim:i32][xdim:i32][data:Complex*ydim*xdim]
+// Complex is stored as (re,im) pairs of RFLOAT
+static void __relion_dump_complex(const std::string& name, const MultidimArray<Complex>& arr) {
+    if (!__relion_dump_enabled) return;
+    std::string path = __relion_dump_dir + "/" + name + ".bin";
+    std::ofstream f(path, std::ios::binary);
+    int32_t ydim = YSIZE(arr), xdim = XSIZE(arr);
+    f.write(reinterpret_cast<const char*>(&ydim), sizeof(int32_t));
+    f.write(reinterpret_cast<const char*>(&xdim), sizeof(int32_t));
+    f.write(reinterpret_cast<const char*>(arr.data), (long)ydim * xdim * sizeof(Complex));
+    f.close();
+    std::cerr << "[DUMP] " << name << " complex shape=(" << ydim << "," << xdim << ")" << std::endl;
+}
+
+// Write a single RFLOAT scalar
+static void __relion_dump_scalar(const std::string& name, RFLOAT val) {
+    if (!__relion_dump_enabled) return;
+    std::string path = __relion_dump_dir + "/" + name + ".bin";
+    std::ofstream f(path, std::ios::binary);
+    f.write(reinterpret_cast<const char*>(&val), sizeof(RFLOAT));
+    f.close();
+    std::cerr << "[DUMP] " << name << " = " << val << std::endl;
+}
+
+// Write a 1D flat array (e.g., exp_Mweight)
+static void __relion_dump_flat(const std::string& name, const MultidimArray<RFLOAT>& arr) {
+    if (!__relion_dump_enabled) return;
+    std::string path = __relion_dump_dir + "/" + name + ".bin";
+    std::ofstream f(path, std::ios::binary);
+    int32_t ndim = MULTIDIM_SIZE(arr);
+    f.write(reinterpret_cast<const char*>(&ndim), sizeof(int32_t));
+    f.write(reinterpret_cast<const char*>(arr.data), (long)ndim * sizeof(RFLOAT));
+    f.close();
+    std::cerr << "[DUMP] " << name << " flat size=" << ndim << std::endl;
+}
+
+static void __relion_dump_vector_real(const std::string& name, const std::vector<RFLOAT>& values) {
+    if (!__relion_dump_enabled) return;
+    std::string path = __relion_dump_dir + "/" + name + ".bin";
+    std::ofstream f(path, std::ios::binary);
+    int32_t ndim = values.size();
+    f.write(reinterpret_cast<const char*>(&ndim), sizeof(int32_t));
+    if (ndim > 0)
+        f.write(reinterpret_cast<const char*>(values.data()), (long)ndim * sizeof(RFLOAT));
+    f.close();
+    std::cerr << "[DUMP] " << name << " vector_real size=" << ndim << std::endl;
+}
+
+static void __relion_dump_vector_int(const std::string& name, const std::vector<int>& values) {
+    if (!__relion_dump_enabled) return;
+    std::string path = __relion_dump_dir + "/" + name + ".bin";
+    std::ofstream f(path, std::ios::binary);
+    int32_t ndim = values.size();
