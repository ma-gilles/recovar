+    f << "nr_classes=" << nr_classes << std::endl;
+    f << "pixel_size=" << pixel_size << std::endl;
+    f << "ori_size=" << ori_size << std::endl;
+    f << "current_size=" << current_size << std::endl;
+    f.close();
+}
+// ---- End dump infrastructure ----
